{
  "kind": "collectionType",
  "collectionName": "project_updates",
  "info": {
    "singularName": "project-update",
    "pluralName": "project-updates",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string"
    },
    "Description": {
      "type": "text"
    },
    "StartDate": {
      "type": "date"
    },
    "Status": {
      "type": "enumeration",
      "enum": [
        "active",
        "completed",
        "planned"
      ]
    },
    "timeline_entries": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::timeline-entry.timeline-entry",
      "mappedBy": "project_update"
    }
  }
}
